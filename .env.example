# WIRE platform configuration. Copy to `.env` and set real values.
# Nothing here has a safe committed default — set these before deploying.

# ── Security (REQUIRED in production) ──
# JWT signing key. If unset, the API mints a random ephemeral key at startup
# (tokens won't survive restarts or work across worker processes). Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# Comma-separated browser origins allowed by CORS (your frontend's URL).
WIRE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Scaling / abuse control ──
# Redis URL for rate limiting shared across API replicas. REQUIRED for any
# multi-process API deployment; single-process falls back to in-memory.
WIRE_REDIS_URL=
# Per-minute budgets and per-user daily quota (defaults: 10 / 20 / 50).
WIRE_RATE_LIMIT_RECONSTRUCTIONS=
WIRE_RATE_LIMIT_AUTH=
WIRE_DAILY_RECONSTRUCTION_QUOTA=

# ── Sessions ──
# Access tokens are short-lived; refresh tokens rotate and are revocable.
WIRE_ACCESS_TOKEN_MINUTES=60
WIRE_REFRESH_TOKEN_DAYS=14

# ── TLS ──
# Emit Strict-Transport-Security. Enable ONLY when serving over HTTPS.
WIRE_ENABLE_HSTS=

# ── Observability (optional) ──
SENTRY_DSN=

# ── Object-storage durability (optional; extra: pip install .[objectstore]) ──
# When WIRE_S3_BUCKET is set, each completed run is mirrored to an
# S3-compatible bucket for durability/DR. Credentials come from the standard
# AWS env/instance mechanisms. Leave WIRE_S3_BUCKET blank to keep runs local.
WIRE_S3_BUCKET=
WIRE_S3_PREFIX=runs
# For non-AWS S3-compatible stores (MinIO, Cloudflare R2, DigitalOcean Spaces):
WIRE_S3_ENDPOINT_URL=

# ── Database ──
# SQLAlchemy async URL. Defaults to a local SQLite file; use Postgres in prod:
#   postgresql+asyncpg://user:pass@host:5432/wire
DATABASE_URL=sqlite+aiosqlite:///./wire_platform.db

# ── LLM (optional; the pipeline runs offline without a key) ──
# Google Gemini API key for the semantic layer.
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash).
WIRE_LLM_MODEL=
